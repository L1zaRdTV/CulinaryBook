<Page x:Class="КулинарнаяКнига.Pages.LoginPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="LoginPage">
    <StackPanel Margin="30" Width="300">
        <TextBox x:Name="tbLogin" Margin="0,0,0,8"/>
        <PasswordBox x:Name="pbPassword" Margin="0,0,0,8"/>
        <Button Content="Войти" Click="Login_Click" Margin="0,0,0,8"/>
        <Button Content="Регистрация" Click="Register_Click"/>
    </StackPanel>
</Page>
