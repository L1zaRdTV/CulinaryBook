<Page x:Class="КулинарнаяКнига.Pages.RecipesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="10">
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top">
            <ComboBox x:Name="cmbCategory" Width="170" SelectionChanged="FilterChanged"/>
            <ComboBox x:Name="cmbSort" Width="180" SelectionChanged="FilterChanged"/>
            <TextBox x:Name="tbSearch" Width="220" TextChanged="FilterChanged"/>
            <Button Content="List" Click="ShowList_Click"/>
            <Button Content="Tiles" Click="ShowTiles_Click"/>
        </StackPanel>

        <Grid>
            <ListView x:Name="lvRecipes" MouseDoubleClick="lvRecipes_MouseDoubleClick">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="130"/></Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding RecipeName}" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="В избранное" Tag="{Binding}" Click="btnLike_Click" Style="{StaticResource MagicButtonStyle}"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <ItemsControl x:Name="icRecipes" Visibility="Collapsed">
                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="230" Margin="6" Padding="8" BorderBrush="#DDD" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding RecipeName}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" MaxHeight="45"/>
                                <Button Content="В избранное" Tag="{Binding}" Click="btnLike_Click" Style="{StaticResource MagicButtonStyle}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <StackPanel Orientation="Horizontal" DockPanel.Dock="Bottom">
            <TextBlock x:Name="tbCount" Margin="0,8,10,0"/>
            <Button Content="Избранное" Click="LikeButton_Click"/>
            <Button Content="Добавить рецепт" Click="Add_Click"/>
        </StackPanel>
    </DockPanel>
</Page>
