<Page x:Class="КулинарнаяКнига.Pages.AddEditRecipePage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"><Grid Margin="10"><Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="2*"/><ColumnDefinition Width="1*"/></Grid.ColumnDefinitions><StackPanel Grid.Column="0"><Image x:Name="PhotoImage" Width="377" Height="256" Stretch="Uniform"/><StackPanel Orientation="Horizontal"><Button Content="←" Click="Prev_Click"/><Button Content="→" Click="Next_Click"/></StackPanel><TextBox x:Name="recipeNamePhoto" IsReadOnly="True"/></StackPanel><StackPanel Grid.Column="1"><TextBox Text="{Binding RecipeName,UpdateSourceTrigger=PropertyChanged}"/><TextBox Text="{Binding Description}" Height="100" AcceptsReturn="True" TextWrapping="Wrap"/><ComboBox x:Name="cmbCategory" DisplayMemberPath="CategoryName"/><ComboBox x:Name="cmbAuthor" DisplayMemberPath="AuthorName"/><TextBox Text="{Binding CookingTime}"/></StackPanel><StackPanel Grid.Column="2"><Button Content="Загрузить фото" Click="Upload_Click"/><Button Content="Сохранить" Click="Save_Click"/><Button Content="Шаги приготовления" Click="Steps_Click"/></StackPanel></Grid></Page>
