<Page x:Class="КулинарнаяКнига.Pages.AddRecipes"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:КулинарнаяКнига.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddRecipes">

    <Grid Background="#FFF8F3EE">
        <Border Margin="40" CornerRadius="14" Background="White" BorderBrush="#FFD8C9BB" BorderThickness="1">
            <Grid Margin="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="PageTitleText" Grid.ColumnSpan="2" Text="Новый рецепт" FontSize="26" FontWeight="Bold" Foreground="#FF3A2A1C" Margin="0,0,0,16"/>

                <TextBlock Grid.Row="1" Text="Название рецепта" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="RecipeNameText" Grid.Row="1" Margin="0,22,16,10" Height="30"/>

                <TextBlock Grid.Row="2" Text="Описание" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="DescriptionText" Grid.Row="2" Margin="0,22,16,10" Height="80" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                <TextBlock Grid.Row="3" Text="Категория" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ComboBox x:Name="CategoryCombo" Grid.Row="3" Margin="0,22,16,10" Height="30"/>

                <TextBlock Grid.Row="4" Text="Автор" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ComboBox x:Name="AuthorCombo" Grid.Row="4" Margin="0,22,16,10" Height="30"/>

                <TextBlock Grid.Row="5" Text="Время приготовления (мин)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="CookingTimeText" Grid.Row="5" Margin="0,22,16,10" Height="30"/>

                <TextBlock Grid.Row="6" Text="Файл изображения" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="RecipeNamePhoto" Grid.Row="6" Margin="0,22,16,0" Height="30" IsReadOnly="True" Background="#FFF5F5F5"/>

                <Border Grid.Column="1" Grid.Row="1" Grid.RowSpan="4" Margin="8,0,0,10" CornerRadius="10" BorderBrush="#FFE3D8CF" BorderThickness="1">
                    <Image x:Name="RecipeImage" Stretch="UniformToFill"/>
                </Border>
                <Button x:Name="SelectImageBtn" Grid.Column="1" Grid.Row="5" Margin="8,22,0,10" Height="34" Content="📷 Выбрать фото" Click="SelectImage_Click"/>

                <StackPanel Grid.ColumnSpan="2" Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,50,0,0">
                    <Button Content="Назад" Width="120" Height="34" Margin="0,0,10,0" Click="ggg_Click"/>
                    <Button x:Name="SaveButton" Content="Сохранить" Width="140" Height="34" Background="#FFE39E54" BorderThickness="0" Foreground="White" FontWeight="SemiBold" Click="Button_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
