<Page x:Class="КулинарнаяКнига.Pages.PageAutoriz"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Вход">

    <Grid Background="#FFF5F1EC">
        <Border Width="420" Padding="28" Background="White" CornerRadius="14" BorderBrush="#FFE1D8CF" BorderThickness="1"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Кулинарная книга" FontSize="28" FontWeight="Bold" Margin="0,0,0,16" Foreground="#FF3A2A1C"/>

                <TextBlock Text="Логин" FontWeight="SemiBold"/>
                <TextBox x:Name="TextLogin" Height="32" Margin="0,6,0,12"/>

                <TextBlock Text="Пароль" FontWeight="SemiBold"/>
                <PasswordBox x:Name="TextPassword" Height="32" Margin="0,6,0,18"/>

                <Button Content="Войти" Height="34" Margin="0,0,0,10" Background="#FFE39E54" BorderThickness="0" Foreground="White" FontWeight="SemiBold" Click="Login_Click"/>
                <Button Content="Регистрация" Height="34" Click="Register_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
