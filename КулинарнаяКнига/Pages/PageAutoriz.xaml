<Page x:Class="КулинарнаяКнига.Pages.PageAutoriz"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:КулинарнаяКнига.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageAutoriz">

    <Grid Margin="0,0,10,0">
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="White"/>
                <GradientStop Color="#FFB92B2B" Offset="0.926"/>
                <GradientStop Color="#FFCA9494" Offset="0.303"/>
            </LinearGradientBrush>
        </Grid.Background>
        <TextBlock HorizontalAlignment="Left" Margin="289,200,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="20" Width="142" Foreground="#FF242188" FontSize="16" FontFamily="Arial Black" Text="Введите логин"/>
        <TextBox x:Name="TextLogin" HorizontalAlignment="Center" Margin="0,225,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="212" Height="25"/>
        <TextBlock HorizontalAlignment="Left" Margin="289,268,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="20" Width="185" Foreground="#FF242188" FontSize="16" FontFamily="Arial Black" Text="Введите пароль"/>
        <Button Content="Войти" HorizontalAlignment="Center" Margin="0,341,0,0" VerticalAlignment="Top" Width="212" Height="27" Click="Button_Click"/>
        <Button x:Name="Regist" Content="Зарегестрироватся" HorizontalAlignment="Center" Margin="0,373,0,0" VerticalAlignment="Top" Width="212" Height="27" Click="Regist_Click"/>
        <PasswordBox x:Name="TextPassword" HorizontalAlignment="Center" Margin="0,293,0,0" VerticalAlignment="Top" Width="212" Height="22"/>
        <Image Margin="266,28,266,274" Source="/vecteezy_chef-hat-doodle-culinary-line-art-illustration_66601111.png" Stretch="Fill" OpacityMask="White"/>

    </Grid>
</Page>
