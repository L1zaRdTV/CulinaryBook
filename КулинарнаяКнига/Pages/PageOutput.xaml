<Page x:Class="КулинарнаяКнига.Pages.PageOutput"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:КулинарнаяКнига.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageOutput">

    <Grid Background="#FFF8F3EE">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="5*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="20,20,20,10" Padding="12" Background="White" CornerRadius="12" BorderBrush="#FFDCCFC4" BorderThickness="1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ComboBox x:Name="ComboFilter" Margin="0,0,10,0" VerticalAlignment="Center" Width="230" Height="30" SelectionChanged="ComboFilter_SelectionChanged"/>
                <ComboBox x:Name="ComboSort" Margin="0,0,10,0" VerticalAlignment="Center" Width="260" Height="30" SelectionChanged="ComboSort_SelectionChanged"/>
                <TextBox x:Name="TextSearch" Margin="0,0,10,0" VerticalAlignment="Center" Width="220" Height="30" TextChanged="TextSearch_TextChanged"/>
                <Button x:Name="AddRecipes" Content="Добавить рецепт" Height="30" Width="140" Click="Button_Click" Background="#FFE39E54" BorderThickness="0" Foreground="White" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <ListView Grid.Row="1" x:Name="ListProducts" Margin="20,0,20,10" BorderThickness="0" Background="Transparent">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Margin" Value="0,0,0,10"/>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="10" Background="White" CornerRadius="10" BorderBrush="#FFE8DDD4" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>

                            <Border Width="160" Height="120" Margin="0,0,12,0" ClipToBounds="True" Grid.Column="0" CornerRadius="8">
                                <Image Source="{Binding CurrentPhoto}" Stretch="UniformToFill"/>
                            </Border>

                            <StackPanel Grid.Column="1" Orientation="Vertical">
                                <TextBlock FontWeight="Bold" FontSize="16" Text="{Binding RecipeName}" Foreground="#FF3A2A1C"/>
                                <TextBlock TextWrapping="Wrap" Margin="0,6,0,0">
                                    <Run Text="Категория: "/>
                                    <Run Text="{Binding Categories.CategoryName}"/>
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" Margin="0,6,0,0">
                                    <Run Text="Описание: "/>
                                    <Run Text="{Binding Description}"/>
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" Margin="0,6,0,0">
                                    <Run Text="Автор: "/>
                                    <Run Text="{Binding Authors.AuthorName}"/>
                                </TextBlock>
                            </StackPanel>

                            <Border Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#FFF6EEE7" CornerRadius="8" Padding="10">
                                <TextBlock TextWrapping="Wrap" FontWeight="SemiBold">
                                    <Run Text="Время: "/>
                                    <Run Text="{Binding CookingTime}"/>
                                    <Run Text=" мин"/>
                                </TextBlock>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Border Grid.Row="2" Margin="20,0,20,20" Padding="8" Background="White" CornerRadius="8" BorderBrush="#FFDCCFC4" BorderThickness="1">
            <TextBlock x:Name="tbCounter" />
        </Border>
        
    </Grid>
</Page>
