<Page x:Class="КулинарнаяКнига.Pages.PageOutput"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:КулинарнаяКнига.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageOutput">

    <Grid>
        
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="Black"/>
                <GradientStop Color="White" Offset="1"/>
                <GradientStop Color="#FFCA9494" Offset="0.257"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="5*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Row="0">
            <ComboBox x:Name="ComboFilter" Margin="5" VerticalAlignment="Center" Width="209" Height="26" SelectionChanged="ComboFilter_SelectionChanged"/>
            <ComboBox x:Name="ComboSort" Margin="5" VerticalAlignment="Top" Width="120" Height="26" SelectionChanged="ComboSort_SelectionChanged"/>
            <TextBox x:Name="TextSearch"  Margin="5" TextWrapping="Wrap" VerticalAlignment="Center" Width="186" Height="26" TextChanged="TextSearch_TextChanged"/>
        </StackPanel>

        <ListView Grid.Row="1" x:Name="ListProducts" Margin="0,0,0,15">

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border>
                    <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="500"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            <Border
                        Width="200"
                        Height="200"
                        Margin="3"
                        ClipToBounds="True"
                        Grid.Column="0">
                            <Image Source="{Binding CurrentPhoto}" Stretch="UniformToFill"/>
                        </Border>
                    <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Left">
                        <TextBlock Height="auto" Text="{Binding RecipeName}"/>
                                <TextBlock TextWrapping="Wrap" Height="auto" Margin="0,0,0,10">
                            <Run Text="Категория: "/>
                            <Run Text="{Binding Categories.CategoryName}"/>
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" Height="auto" Margin="0,0,0,10">
                                    <Run Text="Описание: "/>
                                    <Run Text="{Binding Description}"/>
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" Height="auto" Margin="0,0,0,10">
                                    <Run Text="Автор: "/>
                                    <Run Text="{Binding Authors.AuthorName}"/>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Vertical" HorizontalAlignment="Left">
                                <TextBlock TextWrapping="Wrap" Height="auto" Margin="0,0,0,10">
                                    <Run Text="Время готовки: "/>
                                    <Run Text="{Binding CookingTime}"/>
                                    <Run Text=" минут"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                  </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <TextBlock x:Name="tbCounter" Grid.Row="2" />
        <Button x:Name="AddRecipes" Content="" HorizontalAlignment="Left" Height="35" Margin="27,10,0,0" Grid.Row="2" VerticalAlignment="Top" Width="65" Click="Button_Click"/>
    </Grid>
</Page>
