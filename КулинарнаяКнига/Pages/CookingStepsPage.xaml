<Page x:Class="КулинарнаяКнига.Pages.CookingStepsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Шаги приготовления">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
            <TextBox x:Name="txtStep" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
            <StackPanel Orientation="Horizontal">
                <Button Content="Добавить шаг" Click="btnAddStep_Click" Margin="0,0,8,0" Style="{StaticResource MagicButtonStyle}"/>
                <Button Content="Назад" Click="btnBack_Click" Style="{StaticResource MagicButtonStyle}"/>
            </StackPanel>
        </StackPanel>

        <ListView x:Name="listSteps">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,6" Padding="8" BorderBrush="#DDD" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding StepNumber, StringFormat=Шаг {0}}" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Text="{Binding StepDescription}" TextWrapping="Wrap" Margin="10,0"/>
                            <Button Grid.Column="2" Content="Удалить шаг" Tag="{Binding}" Click="btnDeleteStep_Click" Style="{StaticResource MagicButtonStyle}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </DockPanel>
</Page>
