<Page x:Class="КулинарнаяКнига.Pages.PageReg"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Регистрация">

    <Grid Background="#FFF5F1EC">
        <Border Width="520" Padding="24" Background="White" CornerRadius="14" BorderBrush="#FFE1D8CF" BorderThickness="1"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.ColumnSpan="2" Text="Регистрация автора" FontSize="24" FontWeight="Bold" Margin="0,0,0,16" Foreground="#FF3A2A1C"/>

                <TextBlock Grid.Row="1" Text="Имя" FontWeight="SemiBold"/>
                <TextBox x:Name="TextName" Grid.Row="1" Grid.Column="1" Margin="10,0,0,10" Height="30"/>

                <TextBlock Grid.Row="2" Text="Логин" FontWeight="SemiBold"/>
                <TextBox x:Name="TextLogin" Grid.Row="2" Grid.Column="1" Margin="10,0,0,10" Height="30"/>

                <TextBlock Grid.Row="3" Text="Пароль" FontWeight="SemiBold"/>
                <PasswordBox x:Name="TextPass" Grid.Row="3" Grid.Column="1" Margin="10,0,0,10" Height="30"/>

                <TextBlock Grid.Row="4" Text="Повтор пароля" FontWeight="SemiBold"/>
                <PasswordBox x:Name="TextPassV" Grid.Row="4" Grid.Column="1" Margin="10,0,0,10" Height="30"/>

                <TextBlock Grid.Row="5" Text="Дата рождения" FontWeight="SemiBold"/>
                <DatePicker x:Name="Bid" Grid.Row="5" Grid.Column="1" Margin="10,0,0,10" Height="30"/>

                <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="Назад" Width="120" Height="34" Margin="0,0,10,0" Click="Back_Click"/>
                    <Button x:Name="RegAppliy" Content="Создать" Width="140" Height="34" Background="#FFE39E54" BorderThickness="0" Foreground="White" FontWeight="SemiBold" Click="Register_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
